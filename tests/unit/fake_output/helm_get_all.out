
apiVersion: v2
name: "cert-manager"
version: "1.19.2"
description: "cert-manager is a powerful and extensible X.509 certificate controller for Kubernetes and OpenShift workloads. It will obtain certificates from a variety of Issuers, both popular public Issuers as well as private Issuers, and ensure the certificates are valid and up-to-date, and will attempt to renew certificates at a configured time before expiry."
keywords:
  - "cert-manager"
  - "kube-lego"
  - "letsencrypt"
  - "tls"
home: "https://apps.rancher.io/applications/cert-manager"
maintainers:
  - name: "SUSE LLC"
    url: "https://www.suse.com/"
icon: "https://apps.rancher.io/logos/cert-manager.png"
appVersion: "1.19.2"
annotations:
  helm.sh/images: "- image: dp.apps.rancher.io/containers/cert-manager-acmesolver:1.19.2-3.10\n  name: cert-manager-acmesolver\n- image: dp.apps.rancher.io/containers/cert-manager-cainjector:1.19.2-3.10\n  name: cert-manager-cainjector\n- image: dp.apps.rancher.io/containers/cert-manager-controller:1.19.2-3.10\n  name: cert-manager-controller\n- image: dp.apps.rancher.io/containers/cert-manager-startupapicheck:1.19.2-3.10\n  name: cert-manager-startupapicheck\n- image: dp.apps.rancher.io/containers/cert-manager-webhook:1.19.2-3.10\n  name: cert-manager-webhook\n"
  license: "Apache-2.0"
